$
  y'' + 3y' + 2y = e^x
$

$
         Y(0) & = C_1 \
        Y'(0) & = C_2 \
    cal(L)[y] & = Y(s) \
   cal(L)[y'] & = s Y(s) - C_1 \
  cal(L)[y''] & = s^2 Y(s) - s C_1 - C_2 \
        "LHS" & = s^2 Y(s) - s C_1 - C_2 + 3 (s Y(s) - C_1) + 2 Y(s) \
              & = s^2 Y(s) + 3 s Y(s) + 2 Y(s) - s C_1 - C_2 - 3 C_1 \
        "RHS" & = cal(L)[e^x] = 1 / (s - 1)
$

$
  s^2 Y(s) + 3 s Y(s) + 2 Y(s) - s C_1 - C_2 - 3 C_1 & = 1 / (s - 1) \
  Y(s) (s^2 + 3 s + 2) & = 1 / (s - 1) + s C_1 + C_2 + 3 C_1 \
  Y(s) & = (1 / (s - 1) + s C_1 + C_2 + 3 C_1) / (s^2 + 3 s + 2) \
  Y(s) & = (1 + (s C_1 + C_2 + 3 C_1)(s-1)) / ((s - 1)(s + 1)(s + 2)) \
  Y(s) & = (C_1 s^2 + (2 C_1 + C_2)s - (3C_1 + C_2 - 1)) / ((s - 1)(s + 1)(s + 2))
$

$
  cal(L)^(-1)[Y(s)] = 1/6 (2 - 6C_1 -6C_2) e^(-2t) + 1/2 (4C_1 + 2C_2 - 1)e^(-t) + 1/6 e^t
$
